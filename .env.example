# WooCommerce API Configuration
# Get these from: WooCommerce Settings → Advanced → REST API
NEXT_PUBLIC_WOOCOMMERCE_API_URL=https://your-woocommerce-site.com/wp-json/wc/v3
WOOCOMMERCE_CONSUMER_KEY=ck_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Configuration
# Get these from: https://supabase.com → Project Settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Razorpay Payment Gateway
# Get these from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# SendGrid Email Service
# Get this from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shiprocket Shipping Integration
# Get this from: https://shiprocket.in/dashboard/settings/api
SHIPROCKET_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio/MSG91 SMS Notifications (Optional)
# Get these from: https://www.twilio.com or https://www.msg91.com
# SMS_PROVIDER=twilio or msg91
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# MSG91_AUTH_KEY=...

# Analytics & Monitoring (Optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
# SENTRY_DSN=...

# Application Environment
NODE_ENV=development

# Database Backups (Optional)
# BACKUP_BUCKET_NAME=nuvanaah-backups
# BACKUP_REGION=us-east-1
